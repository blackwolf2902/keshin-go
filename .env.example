# Keshin Environment Variables
#
# Python AI (pydantic-settings) — reads field names directly from .env:
#   groq_api_key=gsk_...
#
# Go Viper — reads KESHIN_ prefix with __ for nesting:
#   KESHIN_GROQ__API_KEY=gsk_...
#
# The .env below works for BOTH. Python reads field names directly.
# Go reads KESHIN_* env vars (export them in shell or set in .env with prefix).

# === LLM Provider API Keys (at least one required) ===

# Groq (free, 30 req/min): https://console.groq.com/keys
groq_api_key=

# Gemini (free): https://aistudio.google.com/apikey
# gemini_api_key=

# OpenRouter (free tier models): https://openrouter.ai/keys
# openrouter_api_key=

# === Provider Base URLs (optional overrides) ===
# groq_base_url=https://api.groq.com/openai/v1
# gemini_base_url=https://generativelanguage.googleapis.com/v1beta/openai
# ollama_base_url=http://localhost:11434
# openrouter_base_url=https://openrouter.ai/api/v1

# === LLM Configuration ===
# llm_provider=groq
# llm_model=llama-3.3-70b-versatile

# === TTS Configuration ===
# tts_provider=edge-tts
# edge_tts_voice=ja-JP-NanamiNeural
